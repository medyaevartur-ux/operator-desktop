{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Zhivaya-Skazka-Operator",
  "version": "4.0.0",
  "identifier": "ru.zhivaya-skazka.operator",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Zhivaya Skazka � Operator",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": "v1Compatible",
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "both",
        "displayLanguageSelector": false,
        "languages": ["Russian", "English"]
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://zhivaya-skazka.ru/api/updater/check?target={{target}}&arch={{arch}}&current_version={{current_version}}"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEFBQTJBMzREQkVBNEQ4QjAKUldTdzJLUytUYU9pcXFzUWxyY0xORVVRUVBvVS9KK2lXOE5TQVdZcmltbWx5bkFRbHRmZ1BpQ2cK"
    }
  }
}